# Скопируйте в .env и заполните. Docker Compose подхватывает .env автоматически;
# имена переменных — как в ASP.NET Core Configuration (секция__Свойство).

# --- Caddy (также подставляются в caddy/Caddyfile через env) ---
DOMAIN=
ACME_EMAIL=
# Обратный прокси на API (Compose по умолчанию: vpncontroller:5080)
# UPSTREAM=vpncontroller:5080

# --- База (SQLite внутри тома /app/data) ---
DatabaseOptions__SqlitePath=data/vpncontroller.db

# --- Подписка провайдера (строки vless для outbounds) ---
SubscriptionRefreshOptions__SubscriptionUrl=
SubscriptionRefreshOptions__RefreshIntervalSeconds=86400

# --- Генерация конфига Xray и vless:// для клиентов ---
# Публичный адрес в подписках пользователей
XrayCoreOptions__PublicHost=
# Первый порт инбаундов; далее +1 на каждый по порядку (совместить с публикацией портов сервиса xray)
XrayCoreOptions__InboundPortFirst=8080
XrayCoreOptions__LogLevel=warning
# Reality: dest, SNI (массив через индексы), ключи
XrayCoreOptions__InboundShared__Dest=
XrayCoreOptions__InboundShared__ServerNames__0=
XrayCoreOptions__InboundShared__PrivateKey=
XrayCoreOptions__InboundShared__PublicKey=
# Десять shortId через запятую, порядок как у Inbounds в appsettings.json
XrayCoreOptions__InboundShortIdsCsv=
