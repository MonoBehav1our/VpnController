# Скопируйте в `.env` в корне репозитория.
# Запуск API: ./scripts/run-vpncontroller.sh  (подхватывает этот файл)
# Caddy в Docker: docker compose up -d  (см. VPNCONTROLLER_UPSTREAM)

# Слушать API (по умолчанию 127.0.0.1:5000 — Caddy проксирует сюда из контейнера)
ASPNETCORE_URLS=http://127.0.0.1:5000

# Caddy / Let's Encrypt
DOMAIN=api.example.com
ACME_EMAIL=you@example.com

# Куда Caddy проксирует (хост:порт API на машине)
VPNCONTROLLER_UPSTREAM=host.docker.internal:5000

# SQLite (относительно каталога приложения, обычно data/vpncontroller.db)
DATABASE_SQLITE_PATH=data/vpncontroller.db

# Подписка (полный URL; в конфиге — SubscriptionRefreshOptions:SubscriptionUrl)
SUBSCRIPTIONS_BASE_URL=https://example.com/sub/
SUBSCRIPTIONS_REFRESH_INTERVAL_SECONDS=86400

# Xray — публичный адрес для vless:// (IP или DNS сервера VPN)
XRAY_PUBLIC_HOST=

# Reality (общие для инбаундов)
XRAY_INBOUND_SHARED_DEST=www.example.com:443
XRAY_INBOUND_SHARED_PRIVATE_KEY=
XRAY_INBOUND_SHARED_PUBLIC_KEY=

# 10 shortId через запятую (порядок = direct-in, sota-01 … sota-09). Перекрывает XrayCoreOptions:InboundShortIds в appsettings.
XRAY_INBOUND_SHORT_IDS=

XRAY_LOG_LEVEL=warning

# POST /api/xray/restart — запись конфига и рестарт (на хосте: true + права на каталог и systemctl)
XRAY_RESTART_ENABLED=true
XRAY_RESTART_CONFIG_PATH=/usr/local/etc/xray/config.json
XRAY_RESTART_COMMAND=systemctl restart xray
