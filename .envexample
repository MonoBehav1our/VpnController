# --- Caddy ---
DOMAIN=
ACME_EMAIL=
# UPSTREAM=vpncontroller:5080

# --- SQLite (путь относительно /app в контейнере) ---
DatabaseOptions__SqlitePath=data/vpncontroller.db

# --- Подписка SOTA (URL — секрет; интервал можно оставить по умолчанию) ---
SotaSubscriptionRefreshOptions__SubscriptionUrl=

# --- Xray Reality (секреты и параметры инбаунда; LogLevel по умолчанию в appsettings.json) ---
XrayCoreOptions__PublicHost=
XrayCoreOptions__Dest=
XrayCoreOptions__ServerName=
XrayCoreOptions__PrivateKey=
XrayCoreOptions__PublicKey=
XrayCoreOptions__MainInboundTag=main-in
XrayCoreOptions__InboundPort=8443
XrayCoreOptions__ShortId=
XrayCoreOptions__Fingerprint=

# --- Куда API пишет конфиг и какой контейнер перезапускать ---
# XRAY_DOCKER_CONTAINER_NAME=xray
# XRAY_CONFIG_DIRECTORY=/xray/config
